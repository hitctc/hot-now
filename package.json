{
  "name": "hot-now",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "zsh ./scripts/dev.sh",
    "dev:local": "zsh ./scripts/dev-local.sh",
    "dev:client": "vite --config vite.config.ts",
    "dev:wechat-resolver": "tsx watch src/wechatResolver/main.ts",
    "start": "node dist/server/main.js",
    "build": "rm -rf dist && npm run build:client && tsc -p tsconfig.json",
    "build:client": "npm run typecheck:client && vite build --config vite.config.ts",
    "typecheck:client": "vue-tsc -p tsconfig.client.json --noEmit",
    "test": "vitest run",
    "db:check": "tsx scripts/db-check.ts",
    "db:snapshot": "tsx scripts/db-snapshot.ts",
    "db:restore": "tsx scripts/db-restore.ts"
  },
  "dependencies": {
    "@mozilla/readability": "^0.6.0",
    "ant-design-vue": "^4.2.6",
    "better-sqlite3": "^12.8.0",
    "cheerio": "^1.1.0",
    "fastify": "^5.0.0",
    "jsdom": "^26.0.0",
    "node-cron": "^4.2.1",
    "nodemailer": "^7.0.0",
    "rss-parser": "^3.13.0",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.0.0",
    "@vitejs/plugin-vue": "^5.2.4",
    "@vue/test-utils": "^2.4.6",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.20.0",
    "typescript": "^5.8.0",
    "vite": "^5.4.14",
    "vite-plugin-vue-devtools": "^7.7.9",
    "vitest": "^3.2.0",
    "vue-tsc": "^2.2.10"
  }
}
