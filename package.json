{
  "name": "hot-now",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "dev:local": "set -a && . ./.env.local && set +a && tsx watch src/main.ts",
    "start": "node dist/main.js",
    "build": "rm -rf dist && tsc -p tsconfig.json",
    "test": "vitest run"
  },
  "dependencies": {
    "@mozilla/readability": "^0.6.0",
    "better-sqlite3": "^12.8.0",
    "cheerio": "^1.1.0",
    "fastify": "^5.0.0",
    "jsdom": "^26.0.0",
    "node-cron": "^4.2.1",
    "nodemailer": "^7.0.0",
    "rss-parser": "^3.13.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.0.0",
    "tsx": "^4.20.0",
    "typescript": "^5.8.0",
    "vitest": "^3.2.0"
  }
}
